# --- Database ---
# Connection string to your Postgres database (Neon, Supabase, Railway, RDS, or self-hosted).
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# --- Auth ---
# Random long secret used to sign session JWTs. Generate one with:
#   openssl rand -base64 48
JWT_SECRET="change-this-to-a-long-random-secret"

# --- Optional: password reset emails ---
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="you@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="you@gmail.com"

# --- Optional: AI-generated IPA phonetic transcriptions ---
# Single key:
# GEMINI_API_KEY="AIzaSy..."
# Or multiple keys (comma-separated) to auto-rotate when one hits its free-tier rate limit:
# GEMINI_API_KEYS="AIzaSy_key_1,AIzaSy_key_2"

NODE_ENV="production"
